          <datasource-dependencies datasource='federated.0zgt3mq0yqzbiw1cwy33n06axdhs'>
            <column caption='Sales number' datatype='real' name='[Calculation_0729393599492096]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='FLOAT(REPLACE([Sales], &quot;,&quot;, &quot;.&quot;))' />
            </column>
            <column caption='CY sales' datatype='real' datatype-customized='true' name='[Calculation_0729393607245827]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Calculation_0729393599492096]&#10;END' />
            </column>
            <column caption='PY sales' datatype='real' name='[Calculation_0729393609379844]' role='measure' type='quantitative'>
