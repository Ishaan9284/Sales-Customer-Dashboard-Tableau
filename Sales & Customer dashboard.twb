            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select year' datatype='integer' default-format='n0;-0' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2021'>
              <calculation class='tableau' formula='2021' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0zgt3mq0yqzbiw1cwy33n06axdhs'>
            <column caption='Profit number' datatype='real' datatype-customized='true' name='[Calculation_0729393600737282]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='FLOAT(REPLACE([Profit], &quot;,&quot;, &quot;.&quot;))' />
            </column>
            <column aggregation='Sum' caption='Current year' datatype='integer' default-format='n0;-0' name='[Calculation_0729393922478092]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column aggregation='Sum' caption='Previous year' datatype='integer' default-format='n0;-0' name='[Calculation_0729393922588685]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[Calculation_0729393922478092] - 1' />
            </column>
            <column caption='CY profit' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_0729393926295566]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] THEN [Calculation_0729393600737282]&#10;END' />
            </column>
            <column caption='PY profit' datatype='real' default-format='n&quot;$&quot;0,K;-&quot;$&quot;0,K' name='[Calculation_0729393927659535]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Parameter 1] - 1  THEN [Calculation_0729393600737282]&#10;END' />
            </column>
            <column caption='% Diff Profit' datatype='real' default-format='p0%' name='[Calculation_0729393928220688]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM([Calculation_0729393926295566]) - SUM([Calculation_0729393927659535])) / SUM([Calculation_0729393927659535])' />
            </column>
            <column caption='{SUM([CY profit])}' datatype='real' name='[Calculation_0729393933545490]' role='measure' type='quantitative' user:unnamed='Sheet 4'>
              <calculation class='tableau' formula='{SUM([Calculation_0729393926295566])}' />
            </column>
            <column caption='{[% Diff Profit]}' datatype='real' name='[Calculation_0729393933578259]' role='measure' type='quantitative' user:unnamed='Sheet 4'>
              <calculation class='tableau' formula='{[Calculation_0729393928220688]}' />
            </column>
            <column caption='Min/Max Profit' datatype='real' name='[Calculation_0729393937022996]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_0729393926295566]) = WINDOW_MAX(SUM([Calculation_0729393926295566]))&#10;THEN SUM([Calculation_0729393926295566])&#10;ELSEIF SUM([Calculation_0729393926295566]) = WINDOW_MIN(SUM([Calculation_0729393926295566]))&#10;THEN SUM([Calculation_0729393926295566])&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
