              <calculation class='tableau' formula='IF SUM([Calculation_0729393607245827]) = WINDOW_MAX(SUM([Calculation_0729393607245827]))&#10;THEN SUM([Calculation_0729393607245827])&#10;ELSEIF SUM([Calculation_0729393607245827]) = WINDOW_MIN(SUM([Calculation_0729393607245827]))&#10;THEN SUM([Calculation_0729393607245827])&#10;END'>
